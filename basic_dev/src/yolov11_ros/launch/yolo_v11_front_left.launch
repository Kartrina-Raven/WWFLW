<?xml version="1.0" encoding="utf-8"?>

<launch>

  <!-- Load Parameter -->
  
  <param name="use_gpu"           value="true" />

  <!-- Start yolov11 and ros wrapper -->
  <node pkg="yolov11_ros" type="yolo_v11.py" name="yolov11_ros_front_left" output="screen" >
    <param name="weight_path"       value="$(find yolov11_ros)/weights/best.pt"/>
    <param name="image_topic"       value="/airsim_node/drone_1/front_left/Scene" />
    <param name="pub_topic"         value="/yolov11/front_left/BoundingBoxes" />
    <param name="camera_frame"       value="camera_color_frame"/>
    <param name="visualize"       value="true"/>
    <param name="conf"              value="0.3" />
  </node>
</launch>
